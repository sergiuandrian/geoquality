<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }} — geoqa report</title>
{% if has_maps %}<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">{% endif %}
<style>
  :root {
    --pass: #1a7f37; --fail: #cf222e; --warn: #9a6700; --error: #cf222e;
    --skip: #6e7781; --bg: #f6f8fa; --card: #ffffff; --border: #d0d7de; --text: #1f2328;
  }
  * { box-sizing: border-box; }
  body { margin: 0; font-family: -apple-system, Segoe UI, Roboto, Helvetica, Arial, sans-serif;
         background: var(--bg); color: var(--text); line-height: 1.45; }
  .wrap { max-width: 1100px; margin: 0 auto; padding: 32px 20px 80px; }
  header h1 { margin: 0 0 4px; font-size: 26px; }
  header .sub { color: var(--skip); font-size: 14px; }
  .banner { margin: 22px 0; padding: 18px 22px; border-radius: 10px; color: #fff;
            font-size: 20px; font-weight: 700; letter-spacing: .3px; }
  .banner.ok { background: var(--pass); }
  .banner.bad { background: var(--fail); }
  .counts { display: flex; flex-wrap: wrap; gap: 10px; margin: 8px 0 28px; }
  .pill { padding: 6px 12px; border-radius: 999px; font-size: 13px; font-weight: 600;
          background: var(--card); border: 1px solid var(--border); }
  .pill .n { font-weight: 800; }
  .layer { background: var(--card); border: 1px solid var(--border); border-radius: 10px;
           margin-bottom: 20px; overflow: hidden; }
  .layer > .head { padding: 14px 18px; border-bottom: 1px solid var(--border);
                   display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .layer .name { font-size: 17px; font-weight: 700; }
  .layer .meta { color: var(--skip); font-size: 13px; }
  .badge { font-size: 12px; font-weight: 800; text-transform: uppercase; padding: 3px 9px;
           border-radius: 6px; color: #fff; }
  .b-pass { background: var(--pass); } .b-fail { background: var(--fail); }
  .b-warn { background: var(--warn); } .b-error { background: var(--error); }
  .b-skip { background: var(--skip); }
  table { width: 100%; border-collapse: collapse; }
  th, td { text-align: left; padding: 10px 18px; border-bottom: 1px solid var(--border);
           vertical-align: top; font-size: 14px; }
  th { background: #fafbfc; font-size: 12px; text-transform: uppercase; color: var(--skip); }
  tr:last-child td { border-bottom: none; }
  td.check { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; white-space: nowrap; }
  .count { color: var(--skip); font-size: 12px; }
  details { margin-top: 6px; }
  summary { cursor: pointer; color: var(--fail); font-size: 13px; }
  ul.issues { margin: 6px 0 0; padding-left: 18px; font-size: 13px; color: #57606a; }
  ul.issues li { margin: 2px 0; }
  footer { color: var(--skip); font-size: 12px; margin-top: 30px; text-align: center; }
  .row-skip td { color: var(--skip); }
  .mapwrap { border-top: 1px solid var(--border); }
  .map { height: 360px; width: 100%; }
  .maphint { padding: 8px 18px; font-size: 12px; color: var(--skip); }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1>{{ title }}</h1>
    <div class="sub">geoqa report · started {{ data.started_at }}{% if data.finished_at %} · finished {{ data.finished_at }}{% endif %}</div>
  </header>

  <div class="banner {{ 'ok' if data.passed else 'bad' }}">
    {{ 'PASSED' if data.passed else 'FAILED' }}
  </div>

  <div class="counts">
    <span class="pill"><span class="n">{{ data.counts.pass }}</span> passed</span>
    <span class="pill"><span class="n">{{ data.counts.fail }}</span> failed</span>
    <span class="pill"><span class="n">{{ data.counts.warn }}</span> warnings</span>
    <span class="pill"><span class="n">{{ data.counts.error }}</span> errors</span>
    <span class="pill"><span class="n">{{ data.counts.skip }}</span> skipped</span>
  </div>

  {% for layer in data.layers %}
  <section class="layer">
    <div class="head">
      <span class="name">{{ layer.layer }}</span>
      <span class="badge b-{{ layer.status }}">{{ layer.status }}</span>
      <span class="meta">
        {{ layer.n_features }} features
        {% if layer.geometry_type %}· {{ layer.geometry_type }}{% endif %}
        {% if layer.crs %}· {{ layer.crs }}{% endif %}
        · {{ layer.source }}
      </span>
    </div>
    <table>
      <thead>
        <tr><th>Check</th><th>Status</th><th>Result</th></tr>
      </thead>
      <tbody>
        {% for r in layer.results %}
        <tr class="{{ 'row-skip' if r.status == 'skip' else '' }}">
          <td class="check">{{ r.check }}</td>
          <td><span class="badge b-{{ r.status }}">{{ r.status }}</span></td>
          <td>
            {{ r.message }}
            {% if r.n_total %}<span class="count"> ({{ r.n_failed }}/{{ r.n_total }})</span>{% endif %}
            {% if r.issues %}
            <details>
              <summary>{{ r.issues|length }} example issue(s){% if r.issues_truncated %} (+{{ r.issues_truncated }} more){% endif %}</summary>
              <ul class="issues">
                {% for issue in r.issues %}
                <li>
                  {% if issue.feature_id is not none %}<code>#{{ issue.feature_id }}</code> — {% endif %}{{ issue.message }}
                </li>
                {% endfor %}
              </ul>
            </details>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% if loop.index0 in map_ids %}
    <div class="mapwrap">
      <div class="map" id="{{ map_ids[loop.index0] }}"></div>
      <div class="maphint">Offending features highlighted in red. Click a feature for the failed checks.</div>
    </div>
    {% endif %}
  </section>
  {% endfor %}

  <footer>Generated by geoqa · data quality for geospatial data</footer>
</div>
{% if has_maps %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script type="application/json" id="geoqa-maps-data">{{ maps_json|safe }}</script>
<script>
(function () {
  var el = document.getElementById('geoqa-maps-data');
  if (!el || typeof L === 'undefined') return;
  var data = JSON.parse(el.textContent);
  Object.keys(data).forEach(function (id) {
    var node = document.getElementById(id);
    if (!node) return;
    var map = L.map(id);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19, attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);
    var style = { color: '#cf222e', weight: 2, fillColor: '#cf222e', fillOpacity: 0.3 };
    var gj = L.geoJSON(data[id], {
      style: style,
      pointToLayer: function (f, latlng) { return L.circleMarker(latlng, Object.assign({ radius: 6 }, style)); },
      onEachFeature: function (f, lyr) {
        var checks = f.properties && f.properties.geoqa_failed_checks;
        if (checks) {
          var fid = (f.id !== undefined && f.id !== null) ? ('#' + f.id + '<br>') : '';
          lyr.bindPopup(fid + checks);
        }
      }
    }).addTo(map);
    try { map.fitBounds(gj.getBounds(), { padding: [20, 20] }); }
    catch (e) { map.setView([0, 0], 2); }
  });
})();
</script>
{% endif %}
</body>
</html>
